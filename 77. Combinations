class Solution(object):
    def combine(self, n, k):
        ans=[]
        def solve(start,temp):
            if len(temp)==k:
                ans.append(temp[:])
                return
            for i in range(start,n+1):
                temp.append(i)
                solve(i+1,temp)
                temp.pop()
        solve(1,[])
        return ans
        
