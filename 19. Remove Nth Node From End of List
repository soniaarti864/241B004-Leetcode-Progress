class Solution(object):
    def removeNthFromEnd(self, head, n):
        length=0
        temp=head
        while temp:
            length+=1
            temp=temp.next
        pos=length-n
        if pos==0:
            return head.next
        temp=head
        for i in range(pos-1):
            temp=temp.next
        temp.next=temp.next.next
        return head
        
